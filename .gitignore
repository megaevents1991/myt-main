# ─── Dependencies ───────────────────────────────────────────
/node_modules
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Next.js ────────────────────────────────────────────────
/.next/
/out/
/build

# ─── Environment variables (NEVER commit secrets) ────────────
.env
.env.*
!.env.example

# ─── Testing / Coverage ─────────────────────────────────────
/coverage

# ─── TypeScript ─────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Debug logs ─────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ─── OS files ───────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── Certificates ───────────────────────────────────────────
*.pem

# ─── Vercel ─────────────────────────────────────────────────
.vercel

# ─── Claude Code (local/personal settings only) ─────────────
.claude/settings.local.json

# ─── VS Code (optional: remove if you want to share settings) ─
.vscode/
